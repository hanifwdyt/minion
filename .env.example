# ===========================================
# Minion (Punakawan) Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to git!

# --- Server ---
PORT=3001
NODE_ENV=production
REPOS_BASE=/root/repos
LOG_LEVEL=info

# --- Claude CLI ---
CLAUDE_CODE_OAUTH_TOKEN=your-claude-oauth-token-here

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# --- GitLab ---
GITLAB_HOST=your-gitlab-instance.com
GITLAB_TOKEN=your-gitlab-personal-access-token
GITLAB_WEBHOOK_SECRET=your-gitlab-webhook-secret

# --- GitHub (optional) ---
# GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# --- Slack (optional) ---
# SLACK_BOT_TOKEN=your-slack-bot-token
# SLACK_SIGNING_SECRET=your-slack-signing-secret
# SLACK_APP_TOKEN=your-slack-app-token

# --- Auth (dashboard login) ---
JWT_SECRET=generate-a-strong-random-string-here
ADMIN_USER=admin
ADMIN_PASS=change-this-to-a-strong-password

# --- VPN (configured separately via systemd) ---
# VPN password stored in /etc/openconnect/password.txt (chmod 600)
# See VPS-SETUP.md for VPN configuration
